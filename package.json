{
  "name": "foodevents",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "deploy": "npm run build && gh-pages -d dist",
    "cy:open": "cypress open",
    "cy:run": "cypress run --browser firefox",
    "allure:clean": "if exist allure-results rmdir /s /q allure-results && if exist allure-report rmdir /s /q allure-report",
    "cy:run:allure": "npm run allure:clean && cypress run --browser firefox",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "cy:allure": "npm run cy:run:allure && npm run allure:generate"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.6"
  },
  "devDependencies": {
    "@cypress/webpack-preprocessor": "6.0.2",
    "@eslint/js": "^9.39.1",
    "@types/cypress": "1.1.6",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "allure-commandline": "^2.33.0",
    "allure-cypress": "^3.2.0",
    "allure-js-commons": "^3.2.0",
    "cypress": "14.2.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "vite": "^7.3.1"
  }
}
